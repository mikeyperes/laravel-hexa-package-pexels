{
    "name": "hexawebsystems/laravel-hexa-package-pexels",
    "description": "Pexels stock photo API integration for the Hexa Core framework.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_pexels\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_pexels\\Providers\\PexelsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
